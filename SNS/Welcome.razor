@page "/SNS/post"
@using BlazorWebAppTest.Model
@using Model.SNS
@using Microsoft.AspNetCore.Components.Sections
@using System.Net.Http.Json
@using System.Text.Json
@inject IHttpClientFactory ClientFactory
@inject HttpClient Http
@using System.Linq



<head>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/4.7.0/css/font-awesome.min.css">
</head>
<style>
    .profile-thumb {
        width: 80px;
        height: 80px;
        border-radius: 50%;
        object-fit: cover;
        object-position: top center;
        border: 2px solid #ddd;
        margin: 0px 30px 20px 0px;
        padding:3%;
    }
</style>

<SectionContent SectionName="PageHeading">
    <h2 class="m-0">Timeline</h2>
</SectionContent>

<div class="d-flex flex-column align-items-center justify-content-center">
    @if (isLoading)
    {
        @* https://app.beeceptor.com/mock-server/json-placeholder *@
        @* https://rapidapi.com/search?term=linkedin&sortBy=ByRelevance *@
        @* <p><em>Loading...</em></p> *@
        @* <svg class="spinner" width="65px" height="65px" viewBox="0 0 66 66" xmlns="http://www.w3.org/2000/svg">
        <circle class="path" fill="none" stroke-width="6" stroke-linecap="round" cx="33" cy="33" r="30"></circle>
    </svg> *@
        @* <div class="spinner-border text-primary" role="status">
        <span class="sr-only">Loading...</span>
    </div> *@
        @*  <div class="spinner-container">
            <svg class="spinner" width="65px" height="65px" viewBox="0 0 66 66">
                <circle class="path" fill="none" stroke-width="6" stroke-linecap="round" cx="33" cy="33" r="30"></circle>
            </svg>
        </div> *@
        <div class="spinner-border" role="status">
            <span class="sr-only">Loading...</span>
        </div>
    }
    else
    {
        foreach (var postobj in post)
        {
            var currentUser = user?.FirstOrDefault(u => u.id == postobj.userId);
            var name1 = currentUser?.firstName;
            var name2 = currentUser?.lastName;
            var username = currentUser?.username ?? "unknown";
            var userId = currentUser?.id;
            var postid = @postobj.id;
            var fullName = $"{name1} {name2}";
            var image = currentUser?.image;
            var likes = postobj.Reactions?.likes;
            var dislikes = postobj.Reactions?.dislikes;
            var views = postobj.views;
            string[] tags = postobj.tags;

            <div class="card w-75" style="margin: 2% 0;">
                <div class="card-body">
                    <div class="d-flex">
                        <div>
                            <img src="@image" alt="Profile" class="profile-thumb">
                        </div>
                        <div class="d-flex flex-column justify-content-center">
                            <h6 class="card-title">
                                <a class="text-decoration-none fw-bold text-secondary" href="/SNS/userProfile/@userId">@fullName</a>
                            </h6>
                            <p class="text-secondary text-opacity-50">
                                @@@username
                            </p>
                        </div>
                    </div>
                    
                    <h5 class="card-subtitle mb-2 text-muted">@postobj.title</h5>
                    <p class="card-text">@postobj.body</p>
                    <p class="mb-3">
                        @foreach(string t in tags)
                        {
                            <span class="text-secondary me-2 fw-bold">#@t</span>
                        }
                    </p>
                    <a href="#" class="btn btn-primary me-2 disabled"><i class="fa fa-thumbs-up me-1"></i><span>@likes</span></a>
                    <a href="#" class="btn btn-danger me-2 disabled"><i class="fa fa-thumbs-down me-1"></i><span>@dislikes</span></a>
                    <a href="/SNS/posts/@postid" class="btn btn-secondary me-2">
                        <i class="fa fa-comments-o"></i>
                        <span>Comments</span>
                    </a>
                    <a href="#" class="btn btn-success me-2 disabled"><i class="fa fa-eye me-1"></i><span>@views</span></a>
                    <a href="#" class="card-link">Report</a>
                </div>
            </div>
        }

    }

</div>

@code {
    private Post1[]? post;
    private User1[]? user;
    private bool isLoading = true;
    protected override async Task OnInitializedAsync()
    {

        //await Task.Yield();

        var client = ClientFactory.CreateClient("SNSPlaceholder");

        // var options = new JsonSerializerOptions { PropertyNameCaseInsensitive = true };
        // var postsTask = client.GetFromJsonAsync<Post1[]>("/posts", options);
        // var usersTask = client.GetFromJsonAsync<User1[]>("/users", options);

        // // var delayTask = Task.Delay(3000);
        // await Task.WhenAll(postsTask, usersTask);
        // isLoading = false;
        // post = postsTask.Result;
        // user = usersTask.Result;


        var postsTask = client.GetFromJsonAsync<JsonDocument>("/posts?limit=0");
        var usersTask = client.GetFromJsonAsync<JsonDocument>("/users?limit=0");

        await Task.WhenAll(postsTask, usersTask);

        // 2. Manually pick the array property ("posts" or "users")
        // and deserialize just that part into your existing variables
        post = postsTask.Result?.RootElement.GetProperty("posts").Deserialize<Post1[]>();
        user = usersTask.Result?.RootElement.GetProperty("users").Deserialize<User1[]>();

        isLoading = false;
    }
}
