@page "/SNS/posts/{PostID:int}"
@inject NavigationManager NavigationManager
@inject IHttpClientFactory ClientFactory
@using BlazorWebAppTest.Model
@using Microsoft.AspNetCore.Components.Sections
@using Model.SNS
@using System.Text.Json

<SectionContent SectionName="PageHeading">
    <h2 class="m-0">Comments</h2>
</SectionContent>

<head>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/4.7.0/css/font-awesome.min.css">
</head>

<style>
    .profile-thumb {
        width: 60px;
        height: 60px;
        border-radius: 50%;
        object-fit: cover;
        object-position: top center;
        border: 2px solid #ddd;
        padding: 6%;
    }
</style>

<div class="d-flex flex-column align-items-center justify-content-center">

    @if (post != null)
    {
        var currentUser = user?.FirstOrDefault(u => u.id == post.userId);
        var userid = currentUser?.id;
        var fname = currentUser?.firstName;
        var lname = currentUser?.lastName;
        var username = currentUser?.username ?? "unknown";
        var image = currentUser?.image;

        <div class="w-75 card p-0">
            <div class="card-header py-3 px-3" style="background-color:#f9f6ff">
                <div class=" d-flex flex-row align-items-center">

                    <div class="pe-4">
                        <img src="@image" alt="Profile" class="profile-thumb">
                    </div>
                    <a class="d-flex flex-column justify-content-center text-decoration-none" href="/SNS/userProfile/@userid" ))">
                        <h6 class="text-secondary fw-bold">@fname @lname </h6>
                        <p class="text-secondary opacity-50 m-0">@@@username</p>
                    </a>

                </div>
            </div>
            <div class="card-body px-3 py-4">
                <h3>
                    @post.title
                </h3>
                <p>
                    @post.body
                </p>
            </div>
            <div class="card-footer p-3" style="background:#f9f6ff">
                @if (comment != null)
                {
                    <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" class="bi bi-chat-quote d-inline" viewBox="0 0 16 16">
                        <path d="M2.678 11.894a1 1 0 0 1 .287.801 11 11 0 0 1-.398 2c1.395-.323 2.247-.697 2.634-.893a1 1 0 0 1 .71-.074A8 8 0 0 0 8 14c3.996 0 7-2.807 7-6s-3.004-6-7-6-7 2.808-7 6c0 1.468.617 2.83 1.678 3.894m-.493 3.905a22 22 0 0 1-.713.129c-.2.032-.352-.176-.273-.362a10 10 0 0 0 .244-.637l.003-.01c.248-.72.45-1.548.524-2.319C.743 11.37 0 9.76 0 8c0-3.866 3.582-7 8-7s8 3.134 8 7-3.582 7-8 7a9 9 0 0 1-2.347-.306c-.52.263-1.639.742-3.468 1.105" />
                        <path d="M7.066 6.76A1.665 1.665 0 0 0 4 7.668a1.667 1.667 0 0 0 2.561 1.406c-.131.389-.375.804-.777 1.22a.417.417 0 0 0 .6.58c1.486-1.54 1.293-3.214.682-4.112zm4 0A1.665 1.665 0 0 0 8 7.668a1.667 1.667 0 0 0 2.561 1.406c-.131.389-.375.804-.777 1.22a.417.417 0 0 0 .6.58c1.486-1.54 1.293-3.214.682-4.112z" />
                    </svg>
                    <p class="d-inline">Comments</p>
                    <div class="pt-3">
                        @foreach (var cmt in comment)
                        {
                            var userobj = user?.FirstOrDefault(u => u.id == cmt.CommentUser?.userId);
                            var userobjid = userobj?.id;
                            var userobjName = userobj?.firstName  ?? "Unknown User";
                            var userobjUsername = userobj?.username ?? "unknown";
                            var userobjImage = userobj?.image ?? "unknown";
                            <hr class="border-danger border-3 opacity-25 my-2">
                            <div class="d-flex flex-column">
                                <a class=" d-flex flex-row align-items-center mb-2 text-decoration-none" href="/SNS/userProfile/@userobjid"))">
                                    <div class="pe-3">
                                        <img src="@userobjImage" alt="Profile" style="width: 40px;height: 40px;" class="profile-thumb">
                                    </div>
                                    <div class="d-flex flex-row">
                                        <p class="text-secondary fw-bold m-0">@userobjName </p> <span class="text-secondary mx-1">•</span>
                                        <p class="text-secondary opacity-75 m-0">@@@userobjUsername</p>
                                    </div>

                                </a>
                                <p class="">@cmt.body</p>
                                <div>
                                    <i class="fa fa-thumbs-up text-secondary"></i>
                                    <span class="text-secondary">@cmt.likes</span>
                                </div>
                                
                            </div>


                        }
                    </div>

                }
                else
                {
                    <h6 class="text-center">No comments yet!</h6>
                }
            </div>
        </div>
    }
    else
    {
        <h3>Post not found!</h3>
        <h6>This post might have been removed</h6>
    }

</div>
@code {
    [Parameter]
    public int PostID { get; set; }

    private Post1? post;
    private User1[]? user;
    private Comment1[]? comment;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            var options = new JsonSerializerOptions { PropertyNameCaseInsensitive = true };
            var client = ClientFactory.CreateClient("SNSPlaceholder");
            var poststask = client.GetFromJsonAsync<Post1>($"/posts/{PostID}");
            var usertask = client.GetFromJsonAsync<JsonDocument>("/users?limit=0",options);
            var commentask = client.GetFromJsonAsync<JsonDocument>($"/posts/{PostID}/comments");
            await Task.WhenAll(poststask, usertask, commentask);

            comment = commentask.Result?.RootElement.GetProperty("comments").Deserialize<Comment1[]>();
            user = usertask.Result?.RootElement.GetProperty("users").Deserialize<User1[]>();
            post = poststask.Result;
        }
        catch(Exception ex)
        {
            string  a = ex.Message;
        }

    }

}

