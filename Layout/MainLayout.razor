@using Microsoft.AspNetCore.Components.Sections
@inherits LayoutComponentBase



<div class="page">
    <div class="sidebar">
        <NavMenu />
    </div>

    <main>
        <div class="top-row px-4">
            <a href="https://learn.microsoft.com/aspnet/core/" target="_blank">About</a>
            
        </div>
        <div class="bg-white my-fixed-element sticky-sm-top border border-bottomp-2 d-flex justify-content-center p-2" style="z-index:1; width: stretch; top: 55px !important;">
            <SectionOutlet SectionName="PageHeading" />
        </div>
        <article class="content" style="padding:7%">
            @Body
        </article>
    </main>
</div>

<div id="blazor-error-ui">
    An unhandled error has occurred.
    <a href="" class="reload">Reload</a>
    <a class="dismiss">🗙</a>
</div>
